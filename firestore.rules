rules_version = '2';

// PickIt biztonsági szabályok (production).
// Másold be ezeket a Firebase Console > Firestore Database > Rules fülre,
// majd kattints a Publish gombra.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Igaz, ha a bejelentkezett user tagja az adott háztartásnak.
    function isMemberOf(householdId) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(householdId))
        && request.auth.uid in
           get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // Aktív tag: benne van a memberIds-ben és nincs felfüggesztve.
    function isActiveMemberOf(householdId) {
      return isMemberOf(householdId)
        && !(request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.get('suspendedMemberIds', []));
    }

    function isHouseholdCreator(householdId) {
      return isMemberOf(householdId)
        && get(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid;
    }

    // Sztring típus + hosszellenőrzés.
    function strLen(v, minLen, maxLen) {
      return v is string && v.size() >= minLen && v.size() <= maxLen;
    }

    function localeOk(data) {
      return !('locale' in data)
        || data.locale in ['hu', 'en', 'de'];
    }

    function fontScaleOk(data) {
      return !('fontScaleLevel' in data)
        || (data.fontScaleLevel is int
            && data.fontScaleLevel >= -3
            && data.fontScaleLevel <= 3);
    }

    function notificationsEnabledOk(data) {
      return !('notificationsEnabled' in data)
        || data.notificationsEnabled is bool;
    }

    function emailOk(data) {
      return !('email' in data) || strLen(data.email, 5, 320);
    }

    // Ugyanabban a családban vannak (pl. duplikált név megkülönböztetéséhez).
    function sharesHouseholdWith(otherUserId) {
      let myHouseholdId = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('householdId', null);
      let otherHouseholdId = get(/databases/$(database)/documents/users/$(otherUserId)).data.get('householdId', null);
      return myHouseholdId != null && myHouseholdId == otherHouseholdId;
    }

    function pushTokensOk(data) {
      return !('pushTokens' in data) || data.pushTokens is list;
    }

    function activityTypeOk(t) {
      return t in [
        'list_created', 'list_renamed', 'list_archived', 'list_deleted',
        'item_added', 'items_added', 'item_checked', 'item_unchecked',
        'item_deleted', 'items_cleared'
      ];
    }

    function favoriteOk(data) {
      return !('favorite' in data) || data.favorite is bool;
    }

    // Felhasználói profil: saját + ugyanazon család tagjainak olvasása.
    match /users/{userId} {
      allow read: if signedIn()
        && (request.auth.uid == userId || sharesHouseholdWith(userId));
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && strLen(request.resource.data.displayName, 1, 100)
        && fontScaleOk(request.resource.data)
        && localeOk(request.resource.data)
        && pushTokensOk(request.resource.data)
        && notificationsEnabledOk(request.resource.data)
        && emailOk(request.resource.data);
      allow delete: if false;
    }

    // Meghívó kód → háztartás párosítás.
    // Bárki bejelentkezett user olvashatja (ez kell a csatlakozáshoz), de a
    // dokumentum csak a háztartás azonosítóját tartalmazza, semmi érzékenyet.
    // Létrehozni/módosítani csak a háztartás tagja tudja.
    match /inviteCodes/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && isActiveMemberOf(request.resource.data.householdId);
      allow update, delete: if signedIn()
        && isActiveMemberOf(resource.data.householdId);
    }

    // Háztartás: kizárólag a tagjai olvashatják/írhatják.
    match /households/{householdId} {
      allow read: if isMemberOf(householdId);

      // Létrehozáskor a létrehozó az egyetlen tag, és ő a createdBy.
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds.hasOnly([request.auth.uid])
        && request.resource.data.memberIds.hasAll([request.auth.uid]);

      allow update: if
        // a) meglévő tag módosít (átnevezés, kilépés) – de a kulcsmezők nem változhatnak
        (isActiveMemberOf(householdId)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.inviteCode == resource.data.inviteCode)
        ||
        // b) új tag csatlakozik – kizárólag saját magát adhatja hozzá
        (signedIn()
          && !(request.auth.uid in resource.data.memberIds)
          && request.resource.data.memberIds.hasAll(resource.data.memberIds)
          && request.resource.data.memberIds.hasAll([request.auth.uid])
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
          && request.resource.data.name == resource.data.name
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.inviteCode == resource.data.inviteCode)
        ||
        // c) létrehozó felfüggeszt / újraaktivál tagot
        (isHouseholdCreator(householdId)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.inviteCode == resource.data.inviteCode
          && request.resource.data.name == resource.data.name
          && request.resource.data.memberIds == resource.data.memberIds
          && request.resource.data.members == resource.data.members
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['suspendedMemberIds'])
          && !(request.auth.uid in request.resource.data.get('suspendedMemberIds', [])))
        ||
        // d) tag kilép – saját magát távolítja el (felfüggesztett is)
        (isMemberOf(householdId)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.inviteCode == resource.data.inviteCode
          && request.resource.data.name == resource.data.name
          && request.resource.data.memberIds.size() == resource.data.memberIds.size() - 1
          && resource.data.memberIds.hasAll(request.resource.data.memberIds)
          && !(request.auth.uid in request.resource.data.memberIds)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'members', 'suspendedMemberIds']));

      allow delete: if isActiveMemberOf(householdId);

      // ---- Listák ----
      match /lists/{listId} {
        allow read: if isActiveMemberOf(householdId);
        allow create, update: if isActiveMemberOf(householdId)
          && strLen(request.resource.data.name, 1, 100)
          && request.resource.data.archived is bool
          && request.resource.data.itemCount is number
          && request.resource.data.checkedCount is number;
        allow delete: if isActiveMemberOf(householdId);

        // ---- Tételek ----
        match /items/{itemId} {
          allow read: if isActiveMemberOf(householdId);

          allow create: if isActiveMemberOf(householdId)
            && strLen(request.resource.data.name, 1, 100)
            && strLen(request.resource.data.quantity, 0, 50)
            && strLen(request.resource.data.category, 0, 50)
            && strLen(request.resource.data.note, 0, 500)
            && request.resource.data.order is number
            // Új tétel mindig bejelöletlen, "senki" által.
            && request.resource.data.checked == false
            && request.resource.data.checkedBy == null;

          allow update: if isActiveMemberOf(householdId)
            && strLen(request.resource.data.name, 1, 100)
            && strLen(request.resource.data.quantity, 0, 50)
            && strLen(request.resource.data.category, 0, 50)
            && strLen(request.resource.data.note, 0, 500)
            && request.resource.data.order is number
            && request.resource.data.checked is bool
            // Bejelölni csak SAJÁT néven lehet: a checkedBy vagy változatlan,
            // vagy null (visszavonás), vagy a saját uid.
            && (request.resource.data.checkedBy == resource.data.checkedBy
                || request.resource.data.checkedBy == null
                || request.resource.data.checkedBy == request.auth.uid);

          allow delete: if isActiveMemberOf(householdId);
        }
      }

      // ---- Katalógus (korábbi tételek) ----
      match /catalog/{catalogId} {
        allow read: if isActiveMemberOf(householdId);
        allow create, update: if isActiveMemberOf(householdId)
          && strLen(request.resource.data.name, 1, 100)
          && request.resource.data.useCount is number
          && favoriteOk(request.resource.data);
        allow delete: if isActiveMemberOf(householdId);
      }

      // ---- Push értesítés aktivitás (csak írás, Cloud Functions olvassa) ----
      match /activity/{activityId} {
        allow create: if isActiveMemberOf(householdId)
          && request.resource.data.actorUid == request.auth.uid
          && strLen(request.resource.data.actorName, 1, 100)
          && strLen(request.resource.data.listName, 1, 100)
          && activityTypeOk(request.resource.data.type);
        allow read, update, delete: if false;
      }
    }

    // Összefoglaló push sor – kizárólag Cloud Functions.
    match /pushBatchQueue/{householdId} {
      allow read, write: if false;
    }
  }
}
